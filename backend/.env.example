# football-data.org free API key (get one at https://www.football-data.org/client/register)
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# Django deploy settings
DEBUG=True
SECRET_KEY=replace_with_a_secure_random_value
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=
DATABASE_URL=

# Feed mode: demo | external
LIVE_FEED_MODE=demo

# Used only when LIVE_FEED_MODE=external
# Endpoint should return JSON payload with keys:
# match_id, timestamp, event_type, team, possession_stat, optional player/x_coord/y_coord
LIVE_FEED_ENDPOINT=
# Optional endpoint for fixture search/autocomplete.
# Expected response shape: {"matches": [{"match_id": "...", "home_team": "...", "away_team": "...", "status": "completed", "start_time": "..."}]}
LIVE_MATCH_SEARCH_ENDPOINT=
LIVE_FEED_API_KEY=
LIVE_FEED_API_KEY_HEADER=Authorization
LIVE_FEED_API_KEY_PREFIX=Bearer 

# Optional box-stats provider for official shots/fouls/possession
MATCH_STATS_ENDPOINT=
MATCH_STATS_API_KEY=
MATCH_STATS_API_KEY_HEADER=Authorization
MATCH_STATS_API_KEY_PREFIX=Bearer 

# API-Football (PRIMARY stats source — shots, possession, fouls, corners)
# Free tier: 100 req/day, register at https://dashboard.api-football.com/ (no card needed)
API_FOOTBALL_KEY=

# Optional: Bzzoiro Sports API token for real match stats fallback
# Docs: https://sports.bzzoiro.com/docs/
BZZOIRO_API_BASE_URL=https://sports.bzzoiro.com/api
BZZOIRO_API_TOKEN=

# Gemini AI analysis
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# AI provider: groq | gemini
AI_PROVIDER=groq
AI_PROVIDER_ORDER=groq,gemini

# Groq (free-tier available): https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
