# ── AI / Gemini ────────────────────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Optional: override the Gemini model (default: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

# ── Football Data API ───────────────────────────────────────────────────────────
# Free-tier key from https://www.football-data.org/client/register
# Covers PL, La Liga, Bundesliga, Serie A, Ligue 1, Champions League + more.
# If omitted, match search falls back to local DB only.
FOOTBALL_DATA_API_KEY=your_football_data_api_key_here

# ── Live Event Feed ─────────────────────────────────────────────────────────────
# Set to "demo" for the built-in simulator, or "external" to use your own feed.
LIVE_FEED_MODE=demo

# Required only when LIVE_FEED_MODE=external:
# LIVE_FEED_ENDPOINT=https://your-feed-provider.com/events
# LIVE_FEED_API_KEY=your_feed_api_key
# LIVE_FEED_API_KEY_HEADER=Authorization
# LIVE_FEED_API_KEY_PREFIX=Bearer

# Custom match search endpoint (optional, fallback after football-data.org):
# LIVE_MATCH_SEARCH_ENDPOINT=https://your-feed-provider.com/matches/search
